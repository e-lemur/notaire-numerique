# Copier en `.env` et compléter avant `npm run deploy:amoy`.
# CE FICHIER NE DOIT JAMAIS CONTENIR DE VRAIES CLÉS — il sert juste de modèle.
# Le fichier `.env` réel est ignoré par git (cf. .gitignore racine).

# Endpoint RPC du testnet Polygon Amoy.
# Public et gratuit : https://rpc-amoy.polygon.technology
# Pour plus de fiabilité, utiliser un fournisseur (Alchemy / Infura / QuickNode)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Clé privée d'un wallet jetable, financé via le faucet :
#   https://faucet.polygon.technology/  (sélectionner Amoy)
# IMPORTANT : ne jamais utiliser ici une clé qui détient de la valeur réelle.
AMOY_PRIVATE_KEY=

# Optionnel : pour `npm run verify:amoy <address>`
# Génère une clé sur https://polygonscan.com/myapikey (le même API key
# fonctionne pour Amoy).
POLYGONSCAN_API_KEY=
