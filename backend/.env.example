# Copiez ce fichier en .env et adaptez les valeurs.

# Secret JWT — DOIT être changé en production (≥ 32 caractères aléatoires)
JWT_SECRET=change-me-in-production-please-use-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Stockage
DATABASE_URL=sqlite:///./data/notaire.db
DATA_DIR=./data
STORAGE_DIR=./storage

# Ancrage blockchain (optionnel — laisser vide pour désactiver)
# WEB3_RPC_URL=http://127.0.0.1:8545
# NOTARY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# WEB3_PRIVATE_KEY=0x...
